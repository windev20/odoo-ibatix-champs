<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Héritage de la fiche produit -->
    <record id="view_product_template_form_ibatix" model="ir.ui.view">
        <field name="name">product.template.form.ibatix</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <field name="description_sale" position="after">
                <field name="operation_cee_id" invisible="type != 'service'"/>
            </field>
        </field>
    </record>

</odoo>
