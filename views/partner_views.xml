<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_res_partner_form_ibatix" model="ir.ui.view">
        <field name="name">res.partner.form.ibatix</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <field name="state_id" position="attributes">
                <attribute name="invisible">not is_company</attribute>
            </field>
            <page name="contact_addresses" position="before">
                <page string="Informations" invisible="is_company">
                    <field name="fiscal_ids">
                        <list editable="bottom">
                            <field name="numero_fiscal" string="Numéro Fiscal"/>
                            <field name="reference_fiscal" string="Référence Fiscal"/>
                            <field name="annee_fiscale" string="Année fiscale"/>
                            <field name="revenu_fiscal" string="Revenu fiscal de référence"/>
                            <field name="currency_id" column_invisible="1"/>
                            <field name="nb_parts_foyer" string="Nombre de parts dans le foyer"/>
                        </list>
                    </field>
                    <group>
                        <field name="categorie_precarite"/>
                        <field name="categorie_mpr"/>
                    </group>
                </page>
            </page>
            <notebook position="inside">
                <page string="Documents">
                    <field name="document_ids" string="Documents">
                        <list editable="bottom">
                            <field name="document_type_id" string="Nom"/>
                            <field name="date" string="Date"/>
                            <field name="file" widget="binary" filename="filename" string="Documents"/>
                            <field name="filename" column_invisible="1"/>
                        </list>
                    </field>
                </page>
            </notebook>
        </field>
    </record>

</odoo>
