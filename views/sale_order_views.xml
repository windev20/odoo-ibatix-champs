<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Héritage du devis / bon de commande -->
    <record id="view_sale_order_form_ibatix" model="ir.ui.view">
        <field name="name">sale.order.form.ibatix</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Champ technique exposé pour les invisible -->
            <xpath expr="//group[@name='partner_details']/field[@name='partner_id']" position="before">
                <field name="partner_is_company" invisible="1"/>
                <field name="partner_badges_html"
                       widget="html"
                       readonly="1"
                       nolabel="1"
                       colspan="2"
                       invisible="not partner_id"/>
            </xpath>

            <!-- Masquer l'adresse de facturation pour les particuliers -->
            <xpath expr="//group[@name='partner_details']/field[@name='partner_invoice_id']" position="attributes">
                <attribute name="invisible">not partner_is_company</attribute>
            </xpath>

            <!-- Adresse complète d'installation sous le champ livraison -->
            <xpath expr="//group[@name='partner_details']/field[@name='partner_shipping_id']" position="after">
                <field name="partner_shipping_address_display"
                       readonly="1"
                       nolabel="1"
                       colspan="2"
                       invisible="not partner_shipping_id"
                       class="text-muted fst-italic small ps-1"/>
            </xpath>

        </field>
    </record>

</odoo>
